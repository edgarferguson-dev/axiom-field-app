# DaNI (Deal Activation & New Income) — Environment Variables
# Copy this file to .env.local and fill in your values.

# Required: Claude API key for pre-call intel, optional AI coaching, scoring
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Google Places API (New) — Text Search for field-read business autofill
# GOOGLE_PLACES_API_KEY=

# Optional: CRM close sync — ghl (default) | hubspot | none
# CRM_PROVIDER=ghl
# CRM_FOLLOWUP_KEY=  (workflow / sequence id; falls back to GHL_WORKFLOW_ID_CLOSE for GHL)

# GoHighLevel (CRM_PROVIDER=ghl)
# GHL_API_KEY=
# GHL_LOCATION_ID=
# GHL_WORKFLOW_ID_CLOSE=
# GHL_API_BASE_URL=https://services.leadconnectorhq.com

# HubSpot (CRM_PROVIDER=hubspot)
# HUBSPOT_ACCESS_TOKEN=

# Geocoding (lead route planner) — reuse Places key if Geocoding API enabled
# GOOGLE_GEOCODING_API_KEY=

# DocuSign embedded signing (see lib/integrations/contracts/docusign.ts)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_USER_ID=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_RSA_PRIVATE_KEY=
# DOCUSIGN_AUTH_SERVER=account.docusign.com
