{
  "name": "axiom-field-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run ports:free && next dev -p 3001",
    "dev:turbo": "npm run ports:free && next dev -p 3001 --turbo",
    "ports:free": "npx --yes kill-port@2.0.1 3000 3001 3002 3010",
    "clean": "npx --yes rimraf@5 .next",
    "dev:fresh": "npm run ports:free && npm run clean && next dev -p 3001",
    "dev:clean": "npm run dev:fresh",
    "clean:next": "npx --yes rimraf@5 .next",
    "build": "next build",
    "build:clean": "npm run clean && npm run build",
    "start": "next start -p 3001",
    "start:3010": "next start -p 3010",
    "lint": "next lint",
    "clean:all": "npx --yes rimraf@5 .next node_modules package-lock.json",
    "reinstall": "npm install && npm run build",
    "fresh": "npm run clean:all && npm install && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.100.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "openai": "^6.33.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.72.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
